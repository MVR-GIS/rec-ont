@prefix recs: <https://usace.mil/ontology/recreation/spatial/> .
@prefix rec: <https://usace.mil/ontology/recreation/> .
@prefix recv: <https://usace.mil/vocabulary/recreation/> .
@prefix usf: <https://usace.mil/ontology/spatial/> .
@prefix upr: <https://usace.mil/ontology/physical-realms/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix sf: <http://www.opengis.net/ont/sf#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

recs: a owl:Ontology ;
    rdfs:label "USACE Recreation Spatial Ontology"@en ;
    dct:title "USACE Recreation Spatial Ontology"@en ;
    dct:description "Spatial-first extension that separates GIS feature representations from recreation business entities and geometries."@en ;
    dct:source "EP 1130-2-550; GeoSPARQL; USACE spatial foundation; USACE physical realms"@en ;
    owl:versionInfo "2.0-draft" ;
    owl:imports rec: , <https://usace.mil/ontology/spatial/> , <https://usace.mil/ontology/physical-realms/> , <http://www.opengis.net/ont/geosparql> .

recs:DirectFeaturePattern a owl:NamedIndividual ;
    rdfs:label "Direct Feature Pattern"@en .

recs:RepresentationFeaturePattern a owl:NamedIndividual ;
    rdfs:label "Representation Feature Pattern"@en .

recs:RecreationSpatialFeature a owl:Class ;
    rdfs:label "Recreation Spatial Feature"@en ;
    rdfs:subClassOf geo:Feature ;
    rdfs:subClassOf usf:SpatialFeature ;
    rdfs:comment "GIS-recordable representation of a recreation entity, source-layer record, zone, or boundary. This is not automatically identical to the business entity it represents."@en .

recs:representsEntity a owl:ObjectProperty ;
    rdfs:label "represents entity"@en ;
    rdfs:domain recs:RecreationSpatialFeature ;
    rdfs:range rec:RecreationDomainEntity ;
    rdfs:comment "Links a spatial feature representation to the recreation business entity it represents."@en .

recs:representsConcept a owl:ObjectProperty ;
    rdfs:label "represents concept"@en ;
    rdfs:domain recs:RecreationSpatialFeature ;
    rdfs:range skos:Concept ;
    rdfs:comment "Links a spatial feature representation to a source-backed classification or vocabulary concept."@en .

rec:hasSpatialRepresentation a owl:ObjectProperty ;
    rdfs:label "has spatial representation"@en ;
    rdfs:domain rec:RecreationDomainEntity ;
    rdfs:range recs:RecreationSpatialFeature ;
    owl:inverseOf recs:representsEntity .

recs:usesSpatialPattern a owl:ObjectProperty ;
    rdfs:label "uses spatial pattern"@en ;
    rdfs:domain recs:RecreationSpatialFeature ;
    rdfs:range owl:Thing .

recs:intersectsPhysicalRealm a owl:ObjectProperty ;
    rdfs:label "intersects physical realm"@en ;
    rdfs:domain recs:RecreationSpatialFeature ;
    rdfs:range upr:PhysicalRealm .

recs:sourceLayerName a owl:DatatypeProperty ;
    rdfs:label "source layer name"@en ;
    rdfs:domain recs:RecreationSpatialFeature ;
    rdfs:range xsd:string .

recs:featureGrain a owl:DatatypeProperty ;
    rdfs:label "feature grain"@en ;
    rdfs:domain recs:RecreationSpatialFeature ;
    rdfs:range xsd:string .

recs:sourceIdentifier a owl:DatatypeProperty ;
    rdfs:label "source identifier"@en ;
    rdfs:domain recs:RecreationSpatialFeature ;
    rdfs:range xsd:string .

recs:RecreationAreaFeature a owl:Class ;
    rdfs:label "Recreation Area Feature"@en ;
    rdfs:subClassOf recs:RecreationSpatialFeature ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty geo:hasGeometry ;
        owl:someValuesFrom sf:Polygon
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty recs:representsEntity ;
        owl:someValuesFrom rec:RecreationArea
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty recs:usesSpatialPattern ;
        owl:hasValue recs:RepresentationFeaturePattern
    ] ;
    rdfs:comment "Recreation Area Feature is a GIS representation class, not a replacement for the domain entity or geometry instance."@en .

recs:RecreationFacilityFeature a owl:Class ;
    rdfs:label "Recreation Facility Feature"@en ;
    rdfs:subClassOf recs:RecreationSpatialFeature ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty geo:hasGeometry ;
        owl:someValuesFrom geo:Geometry
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty recs:representsEntity ;
        owl:someValuesFrom rec:RecreationFacility
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty recs:usesSpatialPattern ;
        owl:hasValue recs:RepresentationFeaturePattern
    ] ;
    rdfs:comment "Recreation Facility Feature is a GIS representation class, not a replacement for the domain entity or geometry instance."@en .

