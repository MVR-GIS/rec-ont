@prefix dct: <http://purl.org/dc/terms/> .
@prefix recv: <https://usace.mil/vocabulary/recreation/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

recv:AnnualPass a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-5.b(4)"@en ;
    skos:broader recv:DayUseFee ;
    skos:definition "Pass providing unlimited day use access for one year, purchasable in person, by mail, or by phone with credit card."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Annual Pass"@en .

recv:CarryingCapacity a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-3.b(1)(a)"@en ;
    skos:broader recv:RecreationManagement ;
    skos:definition "The maximum use level a recreation area can sustain without degradation of resources or visitor experience, including social and resource carrying capacity."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Carrying Capacity"@en .

recv:CollateralForfeiture a skos:Concept ;
    dct:source "EP 1130-2-550 Section 6-3.h(4)"@en ;
    skos:broader recv:ViolationNotice ;
    skos:definition "Payment by alleged violator in lieu of court appearance per the forfeiture schedule approved by the District Court."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Collateral Forfeiture"@en .

recv:EmergencyResponse a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 17"@en ;
    skos:definition "Response to emergencies at recreation areas."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Emergency Response"@en .

recv:FreeNightCampingCoupon a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-3.f(3)"@en ;
    skos:broader recv:CampingFee ;
    skos:definition "Coupon issued to increase awareness of recreation opportunities, redeemable for one free night of camping within one year at the issuing project, not valid for reservable sites."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Free-Night Camping Coupon"@en .

recv:InformationExchange a skos:Concept ;
    dct:source "EP 1130-2-550 Section 15-4.d"@en ;
    skos:broader recv:RecreationManagementSupportProgram ;
    skos:definition "Technology transfer and distribution of research results to bring about program enhancement."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Information Exchange"@en .

recv:InterpretiveProspectus a skos:Concept ;
    dct:source "EP 1130-2-550 Section 5-4.b"@en ;
    skos:broader recv:Interpretation ;
    skos:definition "Document identifying interpretive themes and objectives for a Visitor Center, including design criteria and storyline development."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Interpretive Prospectus"@en .

recv:InterpretiveServicesOutreachProgram a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:altLabel "ISOP"@en ;
    skos:broader recv:Interpretation ;
    skos:definition "USACE program for interpretive services and outreach at civil works water resource projects, based on Freeman Tilden principles of effective interpretation. Includes personal and nonpersonal communication and educational activities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Interpretive Services and Outreach Program"@en .

recv:ManagementAssistance a skos:Concept ;
    dct:source "EP 1130-2-550 Section 15-4.c"@en ;
    skos:broader recv:RecreationManagementSupportProgram ;
    skos:definition "Short-term study (less than one year) or ongoing assistance in managing a recreation component considered a national priority."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Management Assistance"@en .

recv:ManagementStudy a skos:Concept ;
    dct:source "EP 1130-2-550 Section 15-4.b"@en ;
    skos:broader recv:RecreationManagementSupportProgram ;
    skos:definition "Long-term RMSP activity (one year or more) of regional or national significance addressing recreation issues."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Management Study"@en .

recv:MasterPlan a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-3.a"@en ;
    skos:broader recv:RecreationManagement ;
    skos:definition "Comprehensive plan for the development and management of land and water resources at a project, establishing recreation area designations and facility development."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Master Plan"@en .

recv:NationalRecreationReservationService a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-3.g"@en ;
    skos:altLabel "NRRS"@en ;
    skos:broader recv:Reservation ;
    skos:definition "National system for making advance reservations at Federal recreation facilities, also used for fee collection and permit issuance."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "National Recreation Reservation Service"@en .

recv:NaturalResourcesManagementSystem a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 12"@en ;
    skos:altLabel "NRMS"@en ;
    skos:broader recv:RecreationManagement ;
    skos:definition "Electronic system for storing and providing data on Corps natural resources management activities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Natural Resources Management System"@en .

recv:ORVArea a skos:Concept ;
    dct:source "EP 1130-2-550 Section 10-4.a(1)"@en ;
    skos:broader recv:OffRoadVehicleUse ;
    skos:definition "Area designated for off-road vehicle use containing topography suitable to the vehicles and having ready public access."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "ORV Area"@en .

recv:ORVTrail a skos:Concept ;
    dct:source "EP 1130-2-550 Section 10-4.a(2)"@en ;
    skos:broader recv:OffRoadVehicleUse ;
    skos:definition "Trail designated for off-road vehicle use without conflict with other public uses or environmental harm."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "ORV Trail"@en .

recv:OperationalManagementPlan a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-3.a"@en ;
    skos:altLabel "OMP"@en ;
    skos:broader recv:RecreationManagement ;
    skos:definition "Plan that implements the Master Plan through specific operational procedures and management practices."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Operational Management Plan"@en .

recv:OperationsProjectManager a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-4.c(1)"@en ;
    skos:broader recv:RecreationManagement ;
    skos:definition "USACE employee responsible for all aspects of operations, maintenance, and administration of a water resource development project and its natural and cultural resources."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Operations Project Manager"@en .

recv:PepperSprayProgram a skos:Concept ;
    dct:source "EP 1130-2-550 Appendix K"@en ;
    skos:altLabel "OC Program"@en ;
    skos:broader recv:RecreationEnforcement ;
    skos:definition "Program authorizing USACE park rangers to carry Oleoresin Capsicum (Pepper Spray) for self-defensive purposes, based on district position and project activity hazard analysis."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Pepper Spray Program"@en .

recv:RecreationLeadershipAdvisoryTeam a skos:Concept ;
    dct:source "EP 1130-2-550 Section 15-2"@en ;
    skos:broader recv:RecreationManagementSupportProgram ;
    skos:definition "Team providing oversight of the RMSP, evaluating proposals for funding and recommending priorities to HQUSACE."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Recreation Leadership Advisory Team"@en .

recv:ServiceContract a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-3.c"@en ;
    skos:broader recv:RecreationManagement ;
    skos:definition "Contract for services at recreation areas evaluated per OMB Circular A-76 comparing full cost of contracting with in-house cost."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Service Contract"@en .

recv:Snowmobile a skos:Concept ;
    dct:source "EP 1130-2-550 Section 10-4.a(3)"@en ;
    skos:broader recv:OffRoadVehicleUse ;
    skos:definition "Motorized vehicle designed for travel on snow, one type of off-road vehicle requiring designated areas."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Snowmobile"@en .

recv:SpecialEventPermit a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-6.c"@en ;
    skos:broader recv:SpecialUseFee ;
    skos:definition "Permit authorizing special events at recreation areas, with associated permit fee."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Special Event Permit"@en .

recv:VisitorAssistanceTraining a skos:Concept ;
    dct:source "EP 1130-2-550 Section 6-4"@en ;
    skos:broader recv:VisitorAssistanceProgram ;
    skos:definition "Required training curriculum for personnel with visitor assistance responsibilities, consisting of basic, refresher, and management modules."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Visitor Assistance Training"@en .

recv:BikeTrail a skos:Concept ;
    skos:broader recv:TrailFacility ;
    skos:definition "Trail designated for bicycle use."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Bike Trail"@en .

recv:BoatLaunchFee a skos:Concept ;
    skos:broader recv:RecreationFee ;
    skos:definition "Fee for boat ramp use."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Boat Launch Fee"@en .

recv:BoatRamp a skos:Concept ;
    skos:altLabel "Boat Launch"@en ;
    skos:broader recv:RecreationAmenity ;
    skos:definition "Ramp for launching and retrieving boats."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Boat Ramp"@en ;
    skos:scopeNote "Source term for a boat launch asset. The spatial ontology models BoatRampFeature separately when a GIS feature record represents the asset."@en .

recv:BoatSlip a skos:Concept ;
    skos:broader recv:Marina ;
    skos:definition "Individual boat docking space."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Boat Slip"@en .

recv:BoatingAccident a skos:Concept ;
    skos:broader recv:RecreationIncident ;
    skos:definition "Accident involving recreational watercraft."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Boating Accident"@en .

recv:BodyRecovery a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-4.b(3)"@en ;
    skos:broader recv:SearchAndRescue ;
    skos:definition "Recovery operations conducted in coordination with sheriff's department, state police, or other local law enforcement agencies."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Body Recovery"@en .

recv:CampgroundConcessionaire a skos:Concept ;
    skos:broader recv:Concession ;
    skos:definition "Concessionaire operating campground facilities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Campground Concessionaire"@en .

recv:Campsite a skos:Concept ;
    skos:broader recv:Campground ;
    skos:definition "Individual camping unit within campground."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Campsite"@en .

recv:CitationAuthority a skos:Concept ;
    dct:source "EP 1130-2-550 Section 6-3"@en ;
    skos:broader recv:RecreationEnforcement ;
    skos:definition "Authority granted to personnel to issue citations for Title 36 violations, documented by ENG Form 5036-R Certificate of Authority."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Citation Authority"@en .

recv:ClassAArea a skos:Concept ;
    skos:broader recv:RecreationArea ;
    skos:definition "High-density developed recreation area."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Class A Recreation Area"@en .

recv:ClassACampArea a skos:Concept ;
    dct:source "EP 1130-2-550 Appendix M"@en ;
    skos:broader recv:CampAreaClass ;
    skos:definition "Highest class camp area with flush restrooms, potable water, showers, sanitary disposal station, personal fee collection, and all standard amenities. Minimum fee $10 for single user unit, $50 for group."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Class A Camp Area"@en .

recv:ClassBArea a skos:Concept ;
    skos:broader recv:RecreationArea ;
    skos:definition "Moderate development recreation area."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Class B Recreation Area"@en .

recv:ClassBCampArea a skos:Concept ;
    dct:source "EP 1130-2-550 Appendix M"@en ;
    skos:broader recv:CampAreaClass ;
    skos:definition "Camp area with vault restrooms, potable water, sanitary disposal station, and standard amenities but no showers or personal fee collection. Minimum fee $8 for single user unit, $40 for group."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Class B Camp Area"@en .

recv:ClassCArea a skos:Concept ;
    skos:broader recv:RecreationArea ;
    skos:definition "Primitive or minimal development area."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Class C Recreation Area"@en .

recv:ClassCCampArea a skos:Concept ;
    dct:source "EP 1130-2-550 Appendix M"@en ;
    skos:broader recv:CampAreaClass ;
    skos:definition "Camp area with vault restrooms, potable water, and standard amenities. Minimum fee $6 for single user unit, $30 for group."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Class C Camp Area"@en .

recv:ClassDCampArea a skos:Concept ;
    dct:source "EP 1130-2-550 Appendix M"@en ;
    skos:broader recv:CampAreaClass ;
    skos:definition "Basic camp area meeting at least 5 of the first 9 facility criteria. Minimum fee $5 for single user unit, $20 for group."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Class D Camp Area"@en .

recv:ClassECampArea a skos:Concept ;
    dct:source "EP 1130-2-550 Appendix M"@en ;
    skos:altLabel "No-Fee Camp Area"@en ;
    skos:broader recv:CampAreaClass ;
    skos:definition "Camp area meeting fewer than 5 of the first 9 facility criteria. No fee may be charged."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Class E Camp Area"@en .

recv:ConservationEasement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:ProjectEasement ;
    skos:definition "Easement where Corps retains rights to lands for aesthetic, recreation and environmental benefits."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Conservation Easement"@en .

recv:CooperativeAgreement a skos:Concept ;
    dct:source "EP 1130-2-550 Section 5-7"@en ;
    skos:broader recv:RecreationManagement ;
    skos:definition "Agreement between the Corps and nonprofit, tax-exempt corporations or other agencies for educational, scientific, and/or interpretive purposes providing services, programs, or activities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Cooperative Agreement"@en .

recv:DangerZone a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-4.b(2)(g)"@en ;
    skos:broader recv:WaterSafety ;
    skos:definition "Hazardous area including tailwater areas and areas immediately above spillways and dams, marked with signs, buoys, or booms."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Danger Zone"@en .

recv:DesignatedNoWake a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:WaterSurfaceZoning ;
    skos:definition "Water zone designated to protect environmentally sensitive shoreline areas, recreational water access areas from disturbance, and for public safety."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Designated No-Wake"@en .

recv:Drowning a skos:Concept ;
    skos:broader recv:RecreationIncident ;
    skos:definition "Fatal water-related incident."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Drowning"@en .

recv:EnvironmentallySensitiveAreas a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:altLabel "ESA"@en ;
    skos:broader recv:LandClassification ;
    skos:definition "Areas where scientific, ecological, cultural or aesthetic features have been identified. Typically limited or no development of public use is allowed. No agricultural or grazing uses permitted unless necessary for specific resource management benefit."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Environmentally Sensitive Areas"@en .

recv:EquipTrail a skos:Concept ;
    skos:broader recv:TrailFacility ;
    skos:definition "Trail designated for horseback riding."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Equestrian Trail"@en .

recv:Exhibit a skos:Concept ;
    skos:broader recv:Interpretation ;
    skos:definition "Display educating visitors about project resources."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Exhibit"@en .

recv:FeeSchedule a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-3.a"@en ;
    skos:broader recv:RecreationFee ;
    skos:definition "Approved schedule of use fees for camping, day use, and special facilities, submitted annually to MSC Commander for approval."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Fee Schedule"@en .

recv:FishAndWildlifeSanctuary a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:WaterSurfaceZoning ;
    skos:definition "Annual or seasonal restrictions on water areas to protect fish and wildlife species during periods of migration, resting, feeding, nesting, and/or spawning."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Fish and Wildlife Sanctuary"@en .

recv:FishAndWildlilfeAllocation a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:LandAllocation ;
    skos:definition "Lands acquired specifically for the congressionally authorized purpose of fish and wildlife management, referred to as separable fish and wildlife lands. Can only be given a land classification of Wildlife Management."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Fish and Wildlife Allocation"@en .

recv:FishingPier a skos:Concept ;
    skos:broader recv:RecreationAmenity ;
    skos:definition "Structure for shore-based fishing."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Fishing Pier"@en .

recv:FlowageEasement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:ProjectEasement ;
    skos:definition "Easement where Corps retains the right to inundate lands for project operations."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Flowage Easement"@en .

recv:FlushRestroom a skos:Concept ;
    skos:broader recv:Restroom ;
    skos:definition "Restroom with flush toilets and running water."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Flush Restroom"@en .

recv:FoodService a skos:Concept ;
    skos:broader recv:Concession ;
    skos:definition "Food and beverage concession services."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Food Service"@en .

recv:FuelDock a skos:Concept ;
    skos:broader recv:Marina ;
    skos:definition "Facility providing marine fuel."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Fuel Dock"@en ;
    skos:scopeNote "Source term retained as a specific water-access support asset. Generic dock semantics require separate review before broad reuse."@en .

recv:FutureRecreationAreas a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:altLabel "Inactive Recreation Areas"@en ;
    skos:broader recv:MultipleResourceManagement ;
    skos:definition "Areas with site characteristics compatible with potential future recreational development or recreation areas that are closed. Until there is an opportunity to develop or reopen, they are managed for multiple resources."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Future Recreation Areas"@en .

recv:GoldenAccessPassport a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-4.c(4)(b)"@en ;
    skos:broader recv:RecreationFee ;
    skos:definition "Federal pass providing 50 percent discount on recreation use fees for U.S. citizens or permanent residents with permanent disabilities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Golden Access Passport"@en .

recv:GoldenAgePassport a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-4.c(4)(b)"@en ;
    skos:broader recv:RecreationFee ;
    skos:definition "Federal pass providing 50 percent discount on recreation use fees for U.S. citizens or permanent residents 62 years or older."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Golden Age Passport"@en .

recv:GroupCampArea a skos:Concept ;
    skos:broader recv:Campground ;
    skos:definition "Camping area for organized groups."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Group Camp Area"@en .

recv:HazardMarking a skos:Concept ;
    skos:broader recv:WaterSafety ;
    skos:definition "Signs and buoys marking water hazards."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Hazard Marking"@en .

recv:HighDensityRecreation a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:LandClassification ;
    skos:definition "Lands developed for intensive recreational activities for the visiting public including day use areas and/or campgrounds, including areas for commercial concessions and quasi-public development."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "High Density Recreation"@en .

recv:HikingTrail a skos:Concept ;
    skos:broader recv:TrailFacility ;
    skos:definition "Trail designated for foot travel."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Hiking Trail"@en .

recv:Injury a skos:Concept ;
    skos:broader recv:RecreationIncident ;
    skos:definition "Personal injury to recreation visitor."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Visitor Injury"@en .

recv:InterpretiveProgram a skos:Concept ;
    skos:broader recv:Interpretation ;
    skos:definition "Guided educational program for visitors."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Interpretive Program"@en .

recv:InterpretiveSign a skos:Concept ;
    skos:broader recv:Interpretation ;
    skos:definition "Sign providing educational information."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Interpretive Sign"@en .

recv:LandPatrol a skos:Concept ;
    skos:broader recv:Patrol ;
    skos:definition "Vehicle or foot patrol of land areas."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Land Patrol"@en .

recv:LawEnforcementCooperativeAgreement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 7"@en ;
    skos:broader recv:CooperativeAgreement ;
    skos:definition "Agreement between Corps and states or political subdivisions for increased law enforcement services at civil works water resource projects during peak visitation periods."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:PlanOfOperation ;
    skos:prefLabel "Law Enforcement Cooperative Agreement"@en .

recv:LifeJacketLoaner a skos:Concept ;
    skos:broader recv:SafetyEquipment ;
    skos:definition "Station providing free life jacket loans."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Life Jacket Loaner Station"@en .

recv:LowDensityRecreation a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:MultipleResourceManagement ;
    skos:definition "Lands with minimal development or infrastructure that support passive public recreational use such as primitive camping, fishing, hunting, trails, and wildlife viewing."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Low Density Recreation"@en .

recv:MarinaConcessionaire a skos:Concept ;
    skos:broader recv:Concession ;
    skos:definition "Concessionaire operating marina facilities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Marina Concessionaire"@en .

recv:MitigationAllocation a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:LandAllocation ;
    skos:definition "Lands acquired or designated specifically for the congressionally authorized purpose of offsetting losses associated with development of the project, referred to as separable mitigation lands."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Mitigation Allocation"@en .

recv:MitigationClassification a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:LandClassification ;
    skos:definition "Land classification used only for lands with an allocation of Mitigation that were acquired specifically for the purposes of offsetting losses associated with development of the project."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Mitigation"@en .

recv:OpenRecreation a skos:Concept ;
