    skos:broader recv:LandAllocation ;
    skos:definition "Lands acquired for the congressionally authorized purpose of constructing and operating the project, including flood control and hydropower. Most project lands are included in this allocation."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Operations Allocation"@en .

recv:OperationsEasement a skos:Concept ;
