    skos:broader recv:WaterSurfaceZoning ;
    skos:definition "Waters available for year round or seasonal water-based recreational use."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Open Recreation"@en .

recv:OperationsAllocation a skos:Concept ;
