    skos:broader recv:RecreationEnforcement ;
    skos:definition "USACE Natural Resources Management personnel providing visitor assistance and Title 36 enforcement with citation authority."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Park Ranger"@en .

recv:ParkingArea a skos:Concept ;
    skos:broader recv:RecreationAmenity ;
    skos:definition "Designated vehicle parking area."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Parking Area"@en .

recv:PicnicArea a skos:Concept ;
    skos:broader recv:DayUseArea ;
    skos:definition "Area with picnic tables and facilities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Picnic Area"@en .

recv:PlanOfOperation a skos:Concept ;
    dct:source "EP 1130-2-550 Section 7-3.e"@en ;
    skos:broader recv:LawEnforcementCooperativeAgreement ;
    skos:definition "Attachment to law enforcement cooperative agreement specifying project areas, services, schedules, costs, contacts, and billing procedures."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Plan of Operation"@en .

recv:Playground a skos:Concept ;
    skos:broader recv:DayUseArea ;
    skos:definition "Area with play equipment for children."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Playground"@en .

recv:ProjectOperationsClassification a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:LandClassification ;
    skos:definition "Lands required for the dam, spillway, switchyard, levees, dikes, offices, maintenance facilities, and other areas that are used solely for the operation of the project."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Project Operations"@en .

recv:PumpOutStation a skos:Concept ;
    skos:broader recv:Marina ;
    skos:definition "Facility for boat sewage disposal."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Pump Out Station"@en .

recv:RVCampground a skos:Concept ;
    skos:broader recv:Campground ;
    skos:definition "Campground with hookups for recreational vehicles."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "RV Campground"@en .

recv:RecreationAllocation a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:LandAllocation ;
    skos:definition "Lands acquired specifically for the congressionally authorized purpose of recreation, referred to as separable recreation lands. Can only be given a land classification of Recreation."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Recreation Allocation"@en .

recv:RecreationUseFeeProgram a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 9"@en ;
    skos:broader recv:RecreationFee ;
    skos:definition "Program for collecting fees from users of specialized sites, facilities, equipment or services at civil works water resource projects per 16 USC 460l-6a."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Recreation Use Fee Program"@en .

recv:RecreationUseSurvey a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 13"@en ;
    skos:broader recv:VisitorStatistics ;
    skos:definition "Survey conducted to measure recreation use and visitor characteristics at Corps projects."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Recreation Use Survey"@en .

recv:RescueEquipment a skos:Concept ;
    skos:broader recv:SafetyEquipment ;
    skos:definition "Equipment for water rescue operations."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Rescue Equipment"@en .

recv:RestrictedArea a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-4.b(2)(g)"@en ;
    skos:broader recv:WaterSafety ;
    skos:definition "Area with limited or prohibited public access, properly marked with appropriate buoys, markers, signs, or barricades."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Restricted Area"@en .

recv:RestrictedWaterArea a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:WaterSurfaceZoning ;
    skos:definition "Water areas restricted for project operations, safety, and security purposes."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Restricted Water Area"@en .

recv:SeaplaneOperations a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 11"@en ;
    skos:broader recv:RecreationActivity ;
    skos:definition "Operation of seaplanes on civil works project waters, subject to designation and regulation."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Seaplane Operations"@en .

recv:SearchAndRescue a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-4.b(3)"@en ;
    skos:altLabel "SAR"@en ;
    skos:definition "Operations to locate and assist distressed persons."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:BodyRecovery ;
    skos:prefLabel "Search and Rescue"@en .

recv:SelfDepositVaultSystem a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-4.c(4)"@en ;
    skos:broader recv:RecreationFee ;
    skos:definition "Fee collection method using secure honor vault and ENG Form 4839 Self Deposit Permit for small and remote recreation areas to reduce collection costs."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Self-Deposit Vault System"@en .

recv:Shelter a skos:Concept ;
    skos:broader recv:DayUseArea ;
    skos:definition "Covered structure for group picnicking."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Picnic Shelter"@en .

recv:SwimmingArea a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-3.b(4)"@en ;
    skos:altLabel "Beach"@en ;
    skos:broader recv:RecreationFacility ;
    skos:definition "Designated area for swimming, developed and maintained under guidelines of PL 89-72 and EM 1110-2-400."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Swimming Area"@en .

recv:TypeAVisitorCenter a skos:Concept ;
    dct:source "EP 1130-2-550 Section 5-3.c"@en ;
    skos:altLabel "Regional Visitor Center"@en ;
    skos:broader recv:VisitorCenter ;
    skos:definition "Regional Visitor Center serving multiple projects or a major geographic area, with comprehensive exhibits and programs."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Type A Visitor Center"@en .

recv:TypeBVisitorCenter a skos:Concept ;
    dct:source "EP 1130-2-550 Section 5-3.c"@en ;
    skos:altLabel "Project Visitor Center"@en ;
    skos:broader recv:VisitorCenter ;
    skos:definition "Project Visitor Center serving a single project with exhibits and interpretive programs specific to that project."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Type B Visitor Center"@en .

recv:TypeCVisitorCenter a skos:Concept ;
    dct:source "EP 1130-2-550 Section 5-3.c"@en ;
    skos:altLabel "Visitor Information Center"@en ;
    skos:broader recv:VisitorCenter ;
    skos:definition "Visitor Information Center providing basic visitor information and orientation without extensive exhibits."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Type C Visitor Center"@en .

recv:UserPermit a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-3.g"@en ;
    skos:altLabel "ENG Form 4457"@en ;
    skos:broader recv:RecreationFee ;
    skos:definition "Official permit and receipt for fees paid for use of campsites, special sites, facilities, equipment, services, activities, and special events."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "User Permit"@en .

recv:VaultToilet a skos:Concept ;
    skos:broader recv:Restroom ;
    skos:definition "Restroom with vault toilet system."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Vault Toilet"@en .

recv:VegetativeManagement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:MultipleResourceManagement ;
    skos:definition "Lands designated for stewardship of forest, prairie, and other native vegetative cover."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Vegetative Management"@en .

recv:Visitation a skos:Concept ;
    skos:broader recv:VisitorStatistics ;
    skos:definition "Number of visits to recreation areas."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Visitation"@en .

recv:VisitorAssistance a skos:Concept ;
    skos:broader recv:VisitorService ;
    skos:definition "Direct assistance provided to visitors."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Visitor Assistance"@en .

recv:VisitorDay a skos:Concept ;
    skos:broader recv:VisitorStatistics ;
    skos:definition "Unit of recreation use equal to 12 visitor hours."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Visitor Day"@en .

recv:WaterPatrol a skos:Concept ;
    skos:broader recv:Patrol ;
    skos:definition "Boat patrol of water areas."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Water Patrol"@en .

recv:WaterSafetyProgram a skos:Concept ;
    skos:broader recv:WaterSafety ;
    skos:definition "Program educating visitors on water hazards."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Water Safety Program"@en .

recv:WildlifeManagement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:MultipleResourceManagement ;
    skos:definition "Lands designated for stewardship of fish and wildlife resources."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Wildlife Management"@en .

recv:WrittenWarning a skos:Concept ;
    dct:source "EP 1130-2-550 Section 6-3.g"@en ;
    skos:broader recv:Citation ;
    skos:definition "Warning citation prepared on ENG Form 4381 for minor violations, with records maintained for at least two years."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Written Warning"@en .

recv:CampingFee a skos:Concept ;
    skos:broader recv:RecreationFee ;
    skos:definition "Fee for overnight camping."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Camping Fee"@en .

recv:DayUseFee a skos:Concept ;
    skos:broader recv:RecreationFee ;
    skos:definition "Fee for day use area access."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Day Use Fee"@en .

recv:Reservation a skos:Concept ;
    skos:broader recv:VisitorService ;
    skos:definition "Advance booking of recreation facilities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Reservation"@en .

recv:SpecialUseFee a skos:Concept ;
    dct:source "EP 1130-2-550 Section 9-6"@en ;
    skos:broader recv:RecreationFee ;
    skos:definition "Fee for special facility use, special events, or special activities such as group shelters, amphitheaters, and athletic complexes."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Special Use Fee"@en .

recv:ViolationNotice a skos:Concept ;
    dct:source "EP 1130-2-550 Section 6-3.h"@en ;
    skos:broader recv:Citation ;
    skos:definition "Central Violations Bureau form issued for Title 36 violations requiring collateral forfeiture or mandatory court appearance."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Violation Notice"@en .

recv:VisitorAssistanceProgram a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 6"@en ;
    skos:broader recv:RecreationEnforcement ;
    skos:definition "Program for providing visitor assistance and enforcing rules and regulations at recreation areas, including alternative management techniques beyond citation issuance."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Visitor Assistance Program"@en .

recv:Citation a skos:Concept ;
    dct:source "EP 1130-2-550 Section 6-3"@en ;
    skos:broader recv:RecreationEnforcement ;
    skos:definition "Enforcement action for Title 36 regulation violation, including written warnings and violation notices."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:ViolationNotice,
        recv:WrittenWarning ;
    skos:prefLabel "Citation"@en .

recv:Patrol a skos:Concept ;
    skos:broader recv:RecreationEnforcement ;
    skos:definition "Ranger patrol of recreation areas."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:LandPatrol,
        recv:WaterPatrol ;
    skos:prefLabel "Patrol"@en .

recv:RecreationActivity a skos:Concept ;
    skos:definition "Outdoor recreation activity occurring at USACE civil works projects."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:OffRoadVehicleUse,
        recv:SeaplaneOperations ;
    skos:prefLabel "Recreation Activity"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:Restroom a skos:Concept ;
    skos:broader recv:RecreationAmenity ;
    skos:definition "Public toilet facility."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:FlushRestroom,
        recv:VaultToilet ;
    skos:prefLabel "Restroom"@en .

recv:SafetyEquipment a skos:Concept ;
    skos:broader recv:WaterSafety ;
    skos:definition "Equipment for visitor safety."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:LifeJacketLoaner,
        recv:RescueEquipment ;
    skos:prefLabel "Safety Equipment"@en .

recv:VisitorStatistics a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 13"@en ;
    skos:definition "Data on recreation visitation and use patterns."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:RecreationUseSurvey,
        recv:Visitation,
        recv:VisitorDay ;
    skos:prefLabel "Visitor Statistics"@en .

recv:Concession a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-3.b(1)(f)"@en ;
    skos:definition "Commercial services provided under concession agreement for park and recreation purposes."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:CampgroundConcessionaire,
        recv:FoodService,
        recv:MarinaConcessionaire ;
    skos:prefLabel "Concession"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:DayUseArea a skos:Concept ;
    skos:broader recv:RecreationFacility ;
    skos:definition "Area for daytime recreational activities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:PicnicArea,
        recv:Playground,
        recv:Shelter ;
    skos:prefLabel "Day Use Area"@en .

recv:Marina a skos:Concept ;
    skos:broader recv:RecreationFacility ;
    skos:definition "Facility for boat docking and services."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:BoatSlip,
        recv:FuelDock,
        recv:PumpOutStation ;
    skos:prefLabel "Marina"@en ;
    skos:scopeNote "Source term for boating facility. Spatial representation may include area, shoreline, docks, slips, and service features depending on source layer grain."@en .

recv:OffRoadVehicleUse a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 10"@en ;
    skos:altLabel "ORV Use"@en ;
    skos:broader recv:RecreationActivity ;
    skos:definition "Operation of off-road vehicles on designated project lands including areas and trails zoned for such use."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Off-Road Vehicle Use"@en .

recv:ProjectEasement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:definition "Lands for which the Corps holds an easement interest but not fee title. Planned use and management must be in strict accordance with terms and conditions of the easement estate acquired."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:ConservationEasement,
        recv:FlowageEasement,
        recv:OperationsEasement ;
    skos:prefLabel "Project Easement"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:RecreationArea a skos:Concept ;
    skos:definition "Managed area providing recreational opportunities."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:ClassAArea,
        recv:ClassBArea,
        recv:ClassCArea ;
    skos:prefLabel "Recreation Area"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:RecreationIncident a skos:Concept ;
    skos:definition "Safety or security incident at recreation area."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:BoatingAccident,
        recv:Drowning,
        recv:Injury ;
    skos:prefLabel "Recreation Incident"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:RecreationManagementSupportProgram a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 15"@en ;
    skos:altLabel "RMSP"@en ;
    skos:broader recv:RecreationManagement ;
    skos:definition "USACE program providing mechanism for identifying national recreation program priorities through research, management support, and technical information transfer."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Recreation Management Support Program"@en .

recv:TrailFacility a skos:Concept ;
    skos:broader recv:RecreationFacility ;
    skos:definition "Path for hiking, biking, or other trail uses."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:BikeTrail,
        recv:EquipTrail,
        recv:HikingTrail ;
    skos:prefLabel "Trail"@en ;
    skos:scopeNote "Source term retained as vocabulary. The OWL class is rec:Trail; spatial representation is recs:TrailFeature."@en .

recv:VisitorCenter a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 5"@en ;
    skos:broader recv:VisitorService ;
    skos:definition "Facility providing interpretive information to the visiting public about the Corps, its mission, the project and its facilities, visitor safety, and the geographic area."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:TypeAVisitorCenter,
        recv:TypeBVisitorCenter,
        recv:TypeCVisitorCenter ;
    skos:prefLabel "Visitor Center"@en .

recv:VisitorService a skos:Concept ;
    skos:definition "Service provided to recreation visitors."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:Reservation,
        recv:VisitorAssistance,
        recv:VisitorCenter ;
    skos:prefLabel "Visitor Service"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:CampAreaClass a skos:Concept ;
    dct:source "EP 1130-2-550 Appendix M"@en ;
    skos:broader recv:Campground ;
    skos:definition "Classification of camp areas based on facility criteria for fee determination. Classes range from Class A (highest facilities) to Class E (no fee)."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:ClassACampArea,
        recv:ClassBCampArea,
        recv:ClassCCampArea,
        recv:ClassDCampArea,
        recv:ClassECampArea ;
    skos:prefLabel "Camp Area Class"@en .

recv:Campground a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-3.b(2)"@en ;
    skos:broader recv:RecreationFacility ;
    skos:definition "Area with campsites for overnight camping, provided by the Corps, another public agency, or commercial concessions."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:Campsite,
        recv:GroupCampArea,
        recv:RVCampground ;
    skos:prefLabel "Campground"@en .

recv:LandAllocation a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:definition "The congressionally authorized purpose for which project lands were acquired. There are only four land allocation categories applicable to Corps projects."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:FishAndWildlilfeAllocation,
        recv:MitigationAllocation,
        recv:OperationsAllocation,
        recv:RecreationAllocation ;
    skos:prefLabel "Land Allocation"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:MultipleResourceManagement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:broader recv:LandClassification ;
    skos:definition "Land classification allowing for designation of a predominant use with other compatible uses. Land classification maps must reflect the predominant sub-classification."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:FutureRecreationAreas,
        recv:LowDensityRecreation,
        recv:VegetativeManagement,
        recv:WildlifeManagement ;
    skos:prefLabel "Multiple Resource Management"@en .

recv:RecreationAmenity a skos:Concept ;
    skos:definition "Support facility or feature for recreation."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:BoatRamp,
        recv:FishingPier,
        recv:ParkingArea,
        recv:Restroom ;
    skos:prefLabel "Recreation Amenity"@en ;
    skos:scopeNote "Vocabulary concept for support assets. The OWL model treats amenities as managed assets that may have separate spatial representations."@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:WaterSurfaceZoning a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:definition "Classification of project water surface for development and resource management. Included in Master Plan if the project administers a surface water zoning program."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:DesignatedNoWake,
        recv:FishAndWildlifeSanctuary,
        recv:OpenRecreation,
        recv:RestrictedWaterArea ;
    skos:prefLabel "Water Surface Zoning"@en ;
    skos:scopeNote "Classification vocabulary for water surface use. Spatial zone features should represent these concepts explicitly."@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:Interpretation a skos:Concept ;
    skos:definition "Educational programs and exhibits for visitors."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:Exhibit,
        recv:InterpretiveProgram,
        recv:InterpretiveSign ;
    skos:prefLabel "Interpretation"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:LandClassification a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 4"@en ;
    skos:definition "The primary use for which project lands are managed. Project lands are zoned for development and resource management consistent with authorized project purposes and provisions of NEPA and other Federal laws."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:EnvironmentallySensitiveAreas,
        recv:HighDensityRecreation,
        recv:MitigationClassification,
        recv:MultipleResourceManagement,
        recv:ProjectOperationsClassification ;
    skos:prefLabel "Land Classification"@en ;
    skos:scopeNote "Classification vocabulary. Do not automatically convert land-classification values into OWL subclasses."@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:RecreationFacility a skos:Concept ;
    skos:definition "Physical facility supporting recreational use."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:Campground,
        recv:DayUseArea,
        recv:Marina,
        recv:SwimmingArea,
        recv:TrailFacility ;
    skos:prefLabel "Recreation Facility"@en ;
    skos:scopeNote "Vocabulary concept for source language. The OWL model treats facility as a business/domain role, not as a spatial feature or geometry."@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:WaterSafety a skos:Concept ;
    dct:source "EP 1130-2-550 Section 2-4.b"@en ;
    skos:definition "Programs and measures for visitor safety near water, including marking of hazards and restricted areas."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:DangerZone,
        recv:HazardMarking,
        recv:RestrictedArea,
        recv:SafetyEquipment,
        recv:WaterSafetyProgram ;
    skos:prefLabel "Water Safety"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:RecreationEnforcement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 6"@en ;
    skos:definition "Enforcement of rules and regulations at recreation areas per 36 CFR 327."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:Citation,
        recv:CitationAuthority,
        recv:ParkRanger,
        recv:Patrol,
        recv:VisitorAssistanceProgram ;
    skos:prefLabel "Recreation Enforcement"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:RecreationManagement a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 2"@en ;
    skos:definition "Administration and management of USACE recreation programs and facilities at civil works water resource projects."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Recreation Management"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:RecreationFee a skos:Concept ;
    dct:source "EP 1130-2-550 Chapter 9"@en ;
    skos:definition "Fee charged for recreation use or services per 16 USC 460l-6a, assessed for specialized sites, facilities, equipment or services provided at Federal expense."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:narrower recv:BoatLaunchFee,
        recv:CampingFee,
        recv:DayUseFee,
        recv:FeeSchedule,
        recv:GoldenAccessPassport,
        recv:GoldenAgePassport,
        recv:RecreationUseFeeProgram,
        recv:SelfDepositVaultSystem,
        recv:SpecialUseFee,
        recv:UserPermit ;
    skos:prefLabel "Recreation Fee"@en ;
    skos:topConceptOf recv:RecreationConceptScheme .

recv:RecreationConceptScheme a skos:ConceptScheme ;
    dct:created "2025-12-19"^^xsd:date ;
    dct:description "Domain vocabulary for USACE Recreation O&M activities. Covers recreation facilities, visitor services, fee programs, water safety, recreation activities, land allocation, land classification, water surface zoning, and project easements. Derived from EP 1130-2-550."@en,
        "Spatial-first recreation vocabulary preserving source terms as evidence without requiring each term to become an OWL class."@en ;
    dct:modified "2026-01-13"^^xsd:date,
        "2026-06-01" ;
    dct:source "EP 1130-2-550"@en ;
    skos:hasTopConcept recv:Concession,
        recv:Interpretation,
        recv:LandAllocation,
        recv:LandClassification,
        recv:ProjectEasement,
        recv:RecreationActivity,
        recv:RecreationAmenity,
        recv:RecreationArea,
        recv:RecreationEnforcement,
        recv:RecreationFacility,
        recv:RecreationFee,
        recv:RecreationIncident,
        recv:RecreationManagement,
        recv:VisitorService,
        recv:WaterSafety,
        recv:WaterSurfaceZoning ;
    skos:prefLabel "USACE Recreation O&M Vocabulary"@en .
