    skos:broader recv:ProjectEasement ;
    skos:definition "Easement where Corps retains rights to lands necessary for project operations including access."@en ;
    skos:inScheme recv:RecreationConceptScheme ;
    skos:prefLabel "Operations Easement"@en .

recv:ParkRanger a skos:Concept ;
